<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HelpdeskSystem.TicketListPage"
             Title="TicketListPage"
             BackgroundColor="#F1F5F9">

    <VerticalStackLayout Padding = "20" Spacing="15">
        <Label Text="Active IT Support Tickets" FontSize="24" FontAttributes="Bold" TextColor="#1E293B" HorizontalOptions="Center" Margin="0,10"/>
        <Button Text="Refresh Data" BackgroundColor="#10B981" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="45" Clicked="OnRefreshClicked"/>

        <CollectionView x:Name="TicketsListView">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 10" Stroke="#CBD5E1" Margin="0,5" Padding="15" BackgroundColor="White">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" RowSpacing="5">
                            <Label Grid.Row="0" Grid.Column="0" Text="{Binding Title}" FontAttributes="Bold" FontSize="16" TextColor="#1E293B"/>
                            <Label Grid.Row="1" Grid.Column="0" Text="{Binding TicketId, StringFormat='Ticket ID: #{0}'}" FontSize="12" TextColor="#64748B"/>
                            <VerticalStackLayout Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" VerticalOptions="Center" HorizontalOptions="End" Spacing="5">
                                <Label Text="{Binding Priority, StringFormat='Priority: {0}'}" FontAttributes="Bold" FontSize="12" TextColor="#EF4444"/>
                                <Label Text="{Binding Status, StringFormat='Status: {0}'}" FontAttributes="Bold" FontSize="12" TextColor="#2563EB"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>