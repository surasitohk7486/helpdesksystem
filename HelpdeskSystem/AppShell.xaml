<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HelpdeskSystem.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:HelpdeskSystem"
    Shell.FlyoutBehavior="Flyout"
    Title="HelpdeskSystem">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    <Tab Title="IT Dashboard">
        <ShellContent ContentTemplate="{DataTemplate local:TicketListPage}" />
    </Tab>

</Shell>
